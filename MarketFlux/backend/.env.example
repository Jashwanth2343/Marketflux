# =============================================================================
# MarketFlux Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.

# --- Core ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=marketflux
JWT_SECRET=your-secret-key-at-least-32-chars-long-here

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- AI / LLM ---
GEMINI_API_KEY=your-gemini-api-key
# OPENROUTER_API_KEY=your-openrouter-key
# NVIDIA_NIM_API_KEY=your-nvidia-nim-key

# --- Market Data ---
# ALPHA_VANTAGE_KEY=your-key
# FINNHUB_KEY=your-key
# FRED_API_KEY=your-key

# --- Search ---
# TAVILY_API_KEY=your-key

# --- Postgres (vNext / Fund OS) ---
# MARKETFLUX_VNEXT_DATABASE_URL=postgresql://user:pass@localhost:5432/marketflux_vnext
# FUNDOS_DATABASE_URL=postgresql://user:pass@localhost:5432/marketflux_fundos

# --- Redis ---
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# Alpaca Trading API (Paper Trading)
# =============================================================================
# Standard paper trading keys from https://app.alpaca.markets
# Uses TradingClient(paper=True) — single shared paper account.
#
APCA_API_KEY_ID=your-paper-api-key-id
APCA_API_SECRET_KEY=your-paper-api-secret-key

# --- Alpaca Broker API (Multi-tenant / future) ---
# For per-user sub-accounts (test users, multi-tenant deployment).
# Get from: https://broker-app.alpaca.markets (Sandbox dashboard)
# ALPACA_BROKER_API_KEY=your-broker-client-id
# ALPACA_BROKER_API_SECRET=your-broker-client-secret
