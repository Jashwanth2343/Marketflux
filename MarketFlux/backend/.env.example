# =============================================================================
# MarketFlux Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.

# --- Core ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=marketflux
JWT_SECRET=your-secret-key-at-least-32-chars-long-here

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- AI / LLM ---
GEMINI_API_KEY=your-gemini-api-key
# OPENROUTER_API_KEY=your-openrouter-key
# NVIDIA_NIM_API_KEY=your-nvidia-nim-key

# --- Market Data ---
# ALPHA_VANTAGE_KEY=your-key
# FINNHUB_KEY=your-key
# FRED_API_KEY=your-key

# --- Search ---
# TAVILY_API_KEY=your-key

# --- Postgres (vNext / Fund OS) ---
# MARKETFLUX_VNEXT_DATABASE_URL=postgresql://user:pass@localhost:5432/marketflux_vnext
# FUNDOS_DATABASE_URL=postgresql://user:pass@localhost:5432/marketflux_fundos

# --- Redis ---
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# Alpaca Broker API
# =============================================================================
# Get credentials from: https://broker-app.alpaca.markets (Sandbox)
# or https://broker-app.alpaca.markets (Production)

# Required: API credentials
ALPACA_BROKER_API_KEY=your-broker-client-id
ALPACA_BROKER_API_SECRET=your-broker-client-secret

# Environment: "sandbox" (paper trading) or "production" (real money)
ALPACA_ENVIRONMENT=sandbox

# --- Feature Flags ---
# Auto-create Alpaca sub-accounts when users make their first trade
ALPACA_AUTO_CREATE_ACCOUNTS=true
# Sync thesis paper trades to Alpaca for real execution
ALPACA_SYNC_THESIS_TRADES=true
# Enable webhook endpoints for real-time order updates
ALPACA_ENABLE_WEBHOOKS=true
# Allow fractional share orders (via notional amount)
ALPACA_ENABLE_FRACTIONAL=true
# Allow bracket orders (entry + take profit + stop loss)
ALPACA_ENABLE_BRACKET_ORDERS=true
# Allow short selling (disabled by default for safety)
ALPACA_ENABLE_SHORT_SELLING=false

# --- Rate Limiting ---
ALPACA_RATE_LIMIT_RPM=200

# --- Retry Configuration ---
ALPACA_MAX_RETRIES=3
ALPACA_RETRY_BACKOFF_SECONDS=1.0

# --- Order Limits ---
ALPACA_MAX_ORDER_QTY=10000
ALPACA_MAX_NOTIONAL=1000000

# --- Default Order Settings ---
ALPACA_DEFAULT_TIF=day

# --- Webhook Security ---
# HMAC secret for verifying incoming Alpaca webhook payloads
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# ALPACA_WEBHOOK_SECRET=your-webhook-hmac-secret
