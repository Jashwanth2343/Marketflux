# =============================================================================
# MarketFlux Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.

# --- Core ---
JWT_SECRET=your-secret-key-at-least-32-chars-long-here

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- AI / LLM ---
GEMINI_API_KEY=your-gemini-api-key
# OPENROUTER_API_KEY=your-openrouter-key
# NVIDIA_NIM_API_KEY=your-nvidia-nim-key

# --- Market Data ---
# ALPHA_VANTAGE_KEY=your-key
# FINNHUB_KEY=your-key
# FRED_API_KEY=your-key

# --- Search ---
# TAVILY_API_KEY=your-key

# --- Supabase (primary auth + durable data) ---
# Project URL + keys from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Legacy compatibility only ---
# Some older backend paths can still read Mongo mirrors/fallbacks. Do not use
# Mongo as the default local setup unless you are intentionally working on one
# of those legacy paths.
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=marketflux

# --- Redis (hot memory layer) ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# =============================================================================
# Alpaca Paper Trading
# =============================================================================
# ALPACA_MODE controls which API is used:
#   "trading" (default) — single shared paper account, uses APCA_* keys
#   "broker"            — per-user sub-accounts, uses ALPACA_BROKER_* keys
#
ALPACA_MODE=trading

# --- Trading API (default mode) ---
# Standard paper keys from https://app.alpaca.markets
APCA_API_KEY_ID=your-paper-api-key-id
APCA_API_SECRET_KEY=your-paper-api-secret-key

# --- Broker API (multi-tenant mode) ---
# Per-user sub-accounts. Get from: https://broker-app.alpaca.markets
# Set ALPACA_MODE=broker to activate.
# ALPACA_BROKER_API_KEY=your-broker-client-id
# ALPACA_BROKER_API_SECRET=your-broker-client-secret
